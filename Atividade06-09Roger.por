programa {
  funcao exibir_menu_principal()
	{
		limpa()

		escreva("=================================\n")
		escreva("      SISTEMA DA FABRICA\n")
		escreva("=================================\n")
		escreva("1 - Iniciar Linha\n")
		escreva("2 - Pausar Linha\n")
		escreva("3 - Relatório Técnico\n")
		escreva("0 - Desligar Sistema\n")
